# eClaims Environment Variables - Example
# Copy this to .env and customize for your environment

# PostgreSQL Configuration
POSTGRES_DB=eclaims
POSTGRES_USER=eclaims
POSTGRES_PASSWORD=eclaims123

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=eclaims-documents

# Spring Boot Configuration
SPRING_PROFILES_ACTIVE=docker
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# Database Connection
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5435/eclaims
SPRING_DATASOURCE_USERNAME=eclaims
SPRING_DATASOURCE_PASSWORD=eclaims123

# Storage Configuration
STORAGE_MINIO_ENDPOINT=http://minio:9000
STORAGE_MINIO_ACCESS_KEY=minioadmin
STORAGE_MINIO_SECRET_KEY=minioadmin123
STORAGE_MINIO_BUCKET=eclaims-documents

# Mail Configuration
MAIL_SMTP_HOST=mailhog
MAIL_SMTP_PORT=1025
MAIL_SMTP_USERNAME=test
MAIL_SMTP_PASSWORD=test
MAIL_SMTP_AUTH=false

# Application Configuration
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api/v1

# Logging Configuration
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_NAGARRO_ECLAIMS=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=WARN

# JVM Configuration (optional)
JVM_OPTS=-Xms512m -Xmx1024m

